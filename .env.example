# Alpaca Paper Trading API Credentials
ALPACA_API_KEY=<Your key>
ALPACA_SECRET_KEY=<Your secret key>
ALPACA_BASE_URL=https://paper-api.alpaca.markets/v2
ALPACA_DATA_URL=https://data.alpaca.markets/v2

# Trading Configuration
TICKERS=SPY,QQQ,AAPL,MSFT,AMZN,IWM
MODE=live
MAX_RISK_PCT=0.02
MIN_CREDIT_RATIO=0.33
MAX_DELTA=0.20
DRY_RUN=false
SCHEDULE_INTERVAL=5m         # Documentation only — tells the agent its cycle interval

# Risk Guardrails
DAILY_DRAWDOWN_LIMIT=0.05    # Kill process if account drops >5% in one day
MAX_BUYING_POWER_PCT=0.80    # Enter Liquidation Mode if >80% of buying power used
LIQUIDITY_MAX_SPREAD=0.05    # Absolute floor of the underlying bid/ask gate ($)
LIQUIDITY_BPS_OF_MID=0.0005  # Slope of the bid/ask gate (5 bps × mid) — effective threshold = max(floor, slope×mid)
STALE_SPREAD_PCT=0.01        # If (spread / mid) > N, treat the quote as stale and soft-pass instead of hard-fail

# RSI Strategy Gate (opt-in, off by default)
# When enabled, refines the strategy choice between Phase II (CLASSIFY) and
# Phase III (PLAN) using RSI alongside the regime label:
#   sideways + RSI 45-55  → Iron Condor   (full both wings, true neutral)
#   sideways + RSI 55-65  → Bull Put only (skip call wing, lean-bullish drift)
#   sideways + RSI 35-45  → Bear Call only (skip put wing, lean-bearish drift)
#   sideways + extreme    → SKIP cycle    (momentum too active for IC)
#   bullish  + RSI ≥ 70   → SKIP cycle    (overbought, reversal risk)
#   bearish  + RSI ≤ 30   → SKIP cycle    (oversold, reversal risk)
# Toggle this flag to A/B test in the backtester. See trading_agent/rsi_gate.py
# for the full decision matrix and rationale.
RSI_GATE_ENABLED=false

# Alpaca Data Feeds — required on free/basic accounts; paid SIP/OPRA users may override
ALPACA_STOCKS_FEED=iex        # `iex` (free) or `sip` (paid) — used for stock snapshots, bars, bid/ask
ALPACA_OPTIONS_FEED=indicative # `indicative` (free, 15-min delayed) or `opra` (paid real-time)

# Market-data provider selection
# ------------------------------------------------------------------
# Three providers are wired in:
#   `alpaca` — default, full-fidelity (15-min delayed options on free)
#   `schwab` — real-time quotes for Schwab brokerage holders, no extra fee
#   `yahoo`  — yfinance only; no options, no live bid/ask. Useful for the
#              watchlist tab and the backtester where snapshot/option
#              fidelity isn't required.
#
# Per-surface override variables let you mix providers across surfaces.
# Resolution order for each surface:
#   1. MARKET_DATA_PROVIDER_<SURFACE>   (e.g. _LIVE, _WATCHLIST, _BACKTEST)
#   2. MARKET_DATA_PROVIDER             (this global default)
#   3. alpaca                           (hardcoded fallback)
#
# Example: agent trades through Schwab, dashboard uses Alpaca, charts
# use Yahoo:
#   MARKET_DATA_PROVIDER=alpaca
#   MARKET_DATA_PROVIDER_LIVE=schwab
#   MARKET_DATA_PROVIDER_WATCHLIST=alpaca
#   MARKET_DATA_PROVIDER_BACKTEST=yahoo
#
# See trading_agent/market_data_factory.py for the routing logic.
MARKET_DATA_PROVIDER=alpaca
MARKET_DATA_PROVIDER_LIVE=
MARKET_DATA_PROVIDER_WATCHLIST=
MARKET_DATA_PROVIDER_BACKTEST=

# Schwab Trader API — only required when MARKET_DATA_PROVIDER=schwab
# ------------------------------------------------------------------
# Register an app at https://developer.schwab.com → "Add a new app",
# pick "Individual Developer", set the redirect URI to
# https://127.0.0.1:8182, choose the "API Product" = Trader API. After
# the app is approved ("Ready For Use"), copy the App Key + Secret here.
#
# Then run the one-time authorization-code exchange:
#   python -m trading_agent.schwab_oauth login
# That opens a Schwab login URL in your browser; after you approve,
# paste the redirect URL back into the prompt. Tokens persist to
# ~/.schwab_tokens.json (override via SCHWAB_TOKEN_PATH). Refresh
# tokens last 7 days — re-run `login` weekly to avoid downtime.
SCHWAB_CLIENT_ID=
SCHWAB_CLIENT_SECRET=
SCHWAB_REDIRECT_URI=https://127.0.0.1:8182
SCHWAB_TOKEN_PATH=             # optional; defaults to ~/.schwab_tokens.json

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs
TRADE_PLAN_DIR=trade_plans

# Intelligence Layer (LLM + RAG)
# ------------------------------------------------------------------
# Primary analyst (trade reasoning, journaling, RAG retrieval)
# Set LLM_ENABLED=true after running: ollama pull mistral && ollama pull nomic-embed-text
LLM_ENABLED=false
LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=mistral
LLM_EMBEDDING_MODEL=nomic-embed-text
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048
LLM_TIMEOUT=60
TRADE_JOURNAL_DIR=trade_journal
KNOWLEDGE_BASE_DIR=knowledge_base

# ------------------------------------------------------------------
# Sentiment pipeline — FinGPT specialist (stage 2/3)
# Low temperature keeps scoring deterministic; short timeout keeps the
# 5-minute cycle responsive when Ollama is warm.
FINGPT_ENABLED=false
FINGPT_MODEL=qwen2.5-trading
FINGPT_NEWS_LIMIT=10
FINGPT_CACHE_TTL=300
FINGPT_TEMPERATURE=0.1
FINGPT_MAX_TOKENS=512
FINGPT_TIMEOUT=45

# ------------------------------------------------------------------
# Sentiment pipeline — reasoning-model verifier (stage 3/3)
# Anti-hallucination guard.  Local: qwq:32b / deepseek-r1:32b.
# Cloud: set VERIFIER_PROVIDER=anthropic, VERIFIER_MODEL=claude-sonnet-4-6,
# and populate VERIFIER_API_KEY.
VERIFIER_ENABLED=false
VERIFIER_PROVIDER=ollama
VERIFIER_MODEL=qwq:32b
VERIFIER_API_KEY=
VERIFIER_TEMPERATURE=0.15
VERIFIER_MAX_TOKENS=2048
VERIFIER_TIMEOUT=90

# ------------------------------------------------------------------
# News aggregator — free-tier multi-source evidence
NEWS_SOURCES=yahoo,sec_edgar,fed_rss
NEWS_LOOKBACK_HOURS=24
NEWS_MAX_ITEMS_PER_SOURCE=20
NEWS_CACHE_TTL=240
# Optional source-authority overrides as JSON object keyed by source name
# (e.g. {"yahoo": 0.6, "sec_edgar": 1.0, "fed_rss": 0.95}).  Leave blank
# to inherit the defaults in news_aggregator.DEFAULT_SOURCE_WEIGHTS.
NEWS_SOURCE_WEIGHTS_JSON=
# Optional Reddit (PRAW) — register an app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=TradingAgent/1.0
# Optional Twitter / X (recent-search API v2)
TWITTER_BEARER_TOKEN=

# ------------------------------------------------------------------
# Pipeline efficiency gates
# Tier-0 short-circuit: skip LLM entirely when an issuer's earnings are
# already on the public calendar within LOOKAHEAD_DAYS.
EARNINGS_CALENDAR_ENABLED=true
EARNINGS_CALENDAR_LOOKAHEAD_DAYS=7
EARNINGS_CALENDAR_REFRESH_HOURS=12
# Tier-1 hash cache: replay a previously-verified report when the news
# evidence (source+slug+minute_timestamp) hasn't changed.
SENTIMENT_HASH_CACHE_SIZE=32
